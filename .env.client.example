# Example: Both Laptops (.env for CLIENT)
# Location: c:\Users\User\Desktop\PrepSmart-C\client\.env

# ============ API ENDPOINTS ============
# Point to Laptop 1's server (database host)
# Replace 192.168.1.100 with your actual Laptop 1 IP

# HTTP API calls
VITE_API_URL=http://192.168.1.100:5000

# WebSocket for real-time collaboration
VITE_SOCKET_URL=http://192.168.1.100:5000

# ============ DEVELOPMENT ============
VITE_DEBUG=true
