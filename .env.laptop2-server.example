# Example: Laptop 2 (.env for SERVER)
# Location: c:\Users\User\Desktop\PrepSmart-C\server\.env

# ============ DATABASE ============
# Points to LAPTOP 1's PostgreSQL (remote machine)
# Replace 192.168.1.100 with your Laptop 1's actual IP address
DATABASE_URL="postgresql://postgres:postgres123@192.168.1.100:5432/edvance_demo"

# ============ SERVER ============
PORT=5000
NODE_ENV=development

# ============ SECURITY ============
# MUST MATCH Laptop 1's JWT_SECRET
JWT_SECRET="demo-secret-key-make-this-strong-in-production"

# ============ CORS ============
# Allow both localhost and Laptop 2 IP
# Laptop 1 IP for server communication
CORS_ORIGIN="http://localhost:3000,http://192.168.1.101:3000,http://192.168.1.100:5000"

# ============ PYTHON (ML Model) ============
PYTHON_PATH="C:\\Users\\User\\AppData\\Local\\Programs\\Python\\Python312\\python.exe"

# ============ AI APIs (Optional) ============
# Use same keys as Laptop 1 if you want consistency
GOOGLE_API_KEY="your-google-key-here"
GROQ_API_KEY="your-groq-key-here"
LIVEBLOCKS_SECRET_KEY="your-liveblocks-key-here"

# ============ LOGGING ============
DEBUG=true
