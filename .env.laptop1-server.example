# Example: Laptop 1 (.env for SERVER)
# Location: c:\Users\User\Desktop\PrepSmart-C\server\.env

# ============ DATABASE ============
# Points to LOCAL PostgreSQL on this machine
DATABASE_URL="postgresql://postgres:postgres123@localhost:5432/edvance_demo"

# ============ SERVER ============
PORT=5000
NODE_ENV=development

# ============ SECURITY ============
JWT_SECRET="demo-secret-key-make-this-strong-in-production"

# ============ CORS ============
# Allow both localhost and Laptop 1 IP, plus Laptop 2 IP
CORS_ORIGIN="http://localhost:3000,http://192.168.1.100:3000,http://192.168.1.101:3000"

# ============ PYTHON (ML Model) ============
PYTHON_PATH="C:\\Users\\User\\AppData\\Local\\Programs\\Python\\Python312\\python.exe"

# ============ AI APIs (Optional) ============
GOOGLE_API_KEY="your-google-key-here"
GROQ_API_KEY="your-groq-key-here"
LIVEBLOCKS_SECRET_KEY="your-liveblocks-key-here"

# ============ LOGGING ============
DEBUG=true
